---
import '../styles/globals.css'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Halo. Coffee — Your everyday cafe',
  description = 'Your everyday cafe, brewed with care. Fresh every day, for everyone.',
} = Astro.props
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F8F3EA" />
    <title>{title}</title>
  </head>
  <body class="bg-cream text-forest font-sans overflow-x-hidden">
    <slot />
  </body>
</html>
